<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.covoiturage.controller.SignUpController"
      style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);"
      prefWidth="900" prefHeight="600">

    <!-- Title -->
    <VBox alignment="CENTER" spacing="5">
        <Label text="🚗 CovoiturApp" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
        <Label text="Créer un nouveau compte" style="-fx-font-size: 14px; -fx-text-fill: #a8a8b3;"/>
    </VBox>

    <!-- Sign Up Card -->
    <VBox alignment="CENTER" spacing="12" maxWidth="420"
          style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 15; -fx-padding: 35; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 5);">

        <Label text="Inscription" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <TextField fx:id="nomField" promptText="👤 Nom complet"
                   style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                   maxWidth="340"/>

        <TextField fx:id="emailField" promptText="📧 Adresse email"
                   style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                   maxWidth="340"/>

        <TextField fx:id="telephoneField" promptText="📱 Téléphone"
                   style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                   maxWidth="340"/>

        <PasswordField fx:id="passwordField" promptText="🔒 Mot de passe"
                       style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                       maxWidth="340"/>

        <PasswordField fx:id="confirmPasswordField" promptText="🔒 Confirmer le mot de passe"
                       style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                       maxWidth="340"/>

        <!-- Role Selection -->
        <HBox alignment="CENTER" spacing="20">
            <RadioButton fx:id="passagerRadio" text="Passager"
                         style="-fx-text-fill: white; -fx-font-size: 14px;">
                <toggleGroup><ToggleGroup fx:id="roleGroup"/></toggleGroup>
            </RadioButton>
            <RadioButton fx:id="chauffeurRadio" text="Chauffeur"
                         style="-fx-text-fill: white; -fx-font-size: 14px;">
                <toggleGroup><fx:reference source="roleGroup"/></toggleGroup>
            </RadioButton>
        </HBox>

        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e94560; -fx-font-size: 12px;" wrapText="true" maxWidth="340"/>

        <Button text="S'inscrire" onAction="#handleSignUp"
                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 40; -fx-cursor: hand;"
                maxWidth="340"/>

        <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

        <Button text="← Retour à la connexion" onAction="#handleGoToLogin"
                style="-fx-background-color: transparent; -fx-text-fill: #a8a8b3; -fx-font-size: 13px; -fx-cursor: hand;"/>
    </VBox>
</VBox>
