<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.covoiturage.controller.AdminDashboardController"
            style="-fx-background-color: #1a1a2e;">

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 15 25;">
            <Label text="🚗 CovoiturApp" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            <Label text="— Administration" style="-fx-font-size: 16px; -fx-text-fill: #f0a500;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Bienvenue, Admin"
                   style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="🚪 Déconnexion" onAction="#handleLogout"
                    style="-fx-background-color: rgba(233,69,96,0.2); -fx-text-fill: #e94560; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Center -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: #1a1a2e;">

            <!-- Tab 1: Gestion des Utilisateurs -->
            <Tab text="👥 Utilisateurs">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="Gestion des Utilisateurs" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <!-- Stats -->
                    <HBox spacing="15">
                        <VBox alignment="CENTER" spacing="5"
                              style="-fx-background-color: rgba(78,204,163,0.1); -fx-background-radius: 12; -fx-padding: 15 25;"
                              HBox.hgrow="ALWAYS">
                            <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4ecca3;"/>
                            <Label text="Total Utilisateurs" style="-fx-text-fill: #a8a8b3; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5"
                              style="-fx-background-color: rgba(233,69,96,0.1); -fx-background-radius: 12; -fx-padding: 15 25;"
                              HBox.hgrow="ALWAYS">
                            <Label fx:id="blockedUsersLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                            <Label text="Comptes Bloqués" style="-fx-text-fill: #a8a8b3; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5"
                              style="-fx-background-color: rgba(240,165,0,0.1); -fx-background-radius: 12; -fx-padding: 15 25;"
                              HBox.hgrow="ALWAYS">
                            <Label fx:id="totalTrajetsLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f0a500;"/>
                            <Label text="Total Trajets" style="-fx-text-fill: #a8a8b3; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>

                    <TableView fx:id="usersTable" style="-fx-background-color: rgba(255,255,255,0.05);"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                            <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
                            <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                            <TableColumn fx:id="colAttempts" text="Tentatives" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="🔄 Rafraîchir" onAction="#handleRefresh"
                                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="⏸️ Suspendre" onAction="#handleSuspendre"
                                style="-fx-background-color: rgba(240,165,0,0.2); -fx-text-fill: #f0a500; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="🚫 Bloquer" onAction="#handleBloquer"
                                style="-fx-background-color: rgba(233,69,96,0.2); -fx-text-fill: #e94560; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="✅ Réactiver" onAction="#handleReactiver"
                                style="-fx-background-color: rgba(78,204,163,0.2); -fx-text-fill: #4ecca3; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                    </HBox>

                    <Label fx:id="adminMessage" text="" style="-fx-text-fill: #4ecca3; -fx-font-size: 13px;"/>
                </VBox>
            </Tab>

            <!-- Tab 2: Tous les Trajets -->
            <Tab text="🗺️ Tous les Trajets">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="Vue d'ensemble des Trajets" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <TableView fx:id="allTrajetsTable" style="-fx-background-color: rgba(255,255,255,0.05);"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTrajetId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colTrajetDepart" text="Départ" prefWidth="120"/>
                            <TableColumn fx:id="colTrajetArrivee" text="Arrivée" prefWidth="120"/>
                            <TableColumn fx:id="colTrajetDate" text="Date/Heure" prefWidth="160"/>
                            <TableColumn fx:id="colTrajetPrix" text="Prix" prefWidth="80"/>
                            <TableColumn fx:id="colTrajetPlaces" text="Places" prefWidth="80"/>
                            <TableColumn fx:id="colTrajetStatut" text="Statut" prefWidth="100"/>
                            <TableColumn fx:id="colTrajetChauffeur" text="Chauffeur" prefWidth="130"/>
                        </columns>
                    </TableView>

                    <Button text="🔄 Rafraîchir" onAction="#handleRefreshTrajets"
                            style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                </VBox>
            </Tab>

            <!-- Tab 3: Notifications -->
            <Tab text="🔔 Notifications">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Mes Notifications" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Rafraîchir" onAction="#handleRefreshNotifications"
                                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
                    </HBox>

                    <TableView fx:id="notificationsTable" style="-fx-background-color: rgba(255,255,255,0.05);"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNotifDate" text="Date" prefWidth="160"/>
                            <TableColumn fx:id="colNotifMessage" text="Message" prefWidth="450"/>
                            <TableColumn fx:id="colNotifStatut" text="Statut" prefWidth="100"/>
                        </columns>
                    </TableView>
                    
                    <Button text="Marquer tout comme lu" onAction="#handleMarkAllAsRead"
                            style="-fx-background-color: rgba(78,204,163,0.2); -fx-text-fill: #4ecca3; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
