<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.covoiturage.controller.PassengerDashboardController"
            style="-fx-background-color: #1a1a2e;">

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 15 25;">
            <Label text="🚗 CovoiturApp" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Bienvenue, Passager"
                   style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="🚪 Déconnexion" onAction="#handleLogout"
                    style="-fx-background-color: rgba(233,69,96,0.2); -fx-text-fill: #e94560; -fx-background-radius: 8; -fx-padding: 8 15; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Center Content -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #1a1a2e;">

            <!-- Tab 1: Rechercher des Trajets -->
            <Tab text="🔍 Rechercher un Trajet">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <!-- Search Bar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="🔍 Rechercher par ville de départ..."
                                   style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-prompt-text-fill: #a8a8b3; -fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 14px; -fx-pref-width: 350;"/>
                        <Button text="Rechercher" onAction="#handleSearch"
                                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="Tous les trajets" onAction="#handleShowAll"
                                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Trajets Table -->
                    <TableView fx:id="trajetsTable" style="-fx-background-color: rgba(255,255,255,0.05);"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDepart" text="Départ" prefWidth="120"/>
                            <TableColumn fx:id="colArrivee" text="Arrivée" prefWidth="120"/>
                            <TableColumn fx:id="colDate" text="Date/Heure" prefWidth="160"/>
                            <TableColumn fx:id="colPrix" text="Prix (DT)" prefWidth="90"/>
                            <TableColumn fx:id="colPlaces" text="Places" prefWidth="80"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="📌 Réserver ce trajet" onAction="#handleReserver"
                                style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 30; -fx-cursor: hand;"/>
                    </HBox>

                    <Label fx:id="trajetMessage" text="" style="-fx-text-fill: #4ecca3; -fx-font-size: 13px;"/>
                </VBox>
            </Tab>

            <!-- Tab 2: Mes Réservations -->
            <Tab text="📋 Mes Réservations">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="Mes Réservations" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <TableView fx:id="reservationsTable" style="-fx-background-color: rgba(255,255,255,0.05);"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colResId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colResTrajet" text="Trajet" prefWidth="200"/>
                            <TableColumn fx:id="colResDate" text="Date Réservation" prefWidth="160"/>
                            <TableColumn fx:id="colResStatut" text="Statut" prefWidth="120"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="🔄 Rafraîchir" onAction="#handleRefreshReservations"
                                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        <Button text="❌ Annuler la réservation" onAction="#handleAnnulerReservation"
                                style="-fx-background-color: rgba(233,69,96,0.2); -fx-text-fill: #e94560; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                    </HBox>

                    <Label fx:id="reservationMessage" text="" style="-fx-text-fill: #4ecca3; -fx-font-size: 13px;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
